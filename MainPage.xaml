<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TimeSnap.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TimeSnap"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Escape" Invoked="EscapeKey_Invoked"/>
        <KeyboardAccelerator Key="Left"   Invoked="LeftArrow_Invoked"/>
        <KeyboardAccelerator Key="Right"  Invoked="RightArrow_Invoked"/>
    </Page.KeyboardAccelerators>

    <Page.Resources>

        <!-- Thumbnail card: image + time on the left half, window title on the right.
             Uses {Binding} (not x:Bind) — avoids WMC1509 LocalAssembly issues in
             unpackaged WinUI 3 builds. -->
        <DataTemplate x:Key="ThumbnailTemplate">
            <Border CornerRadius="6"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="4">
                <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: thumbnail + time -->
                    <StackPanel Grid.Column="0" Spacing="3">
                        <Image Source="{Binding Thumbnail}"
                               Height="62"
                               HorizontalAlignment="Stretch"
                               Stretch="UniformToFill"/>
                        <TextBlock Text="{Binding TimeAndMonitorText}"
                                   TextAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Right: window title -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding WindowTitle}"
                               TextWrapping="Wrap"
                               MaxLines="4"
                               VerticalAlignment="Top"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="ThumbnailItemStyle" TargetType="ListViewItem"
               BasedOn="{StaticResource DefaultListViewItemStyle}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Week navigation header ═══════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevWeekButton" Grid.Column="0"
                        Click="PrevWeek_Click"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE76B;" FontSize="14"/>
                </Button>

                <!-- Center: week label + optional "go to current week" button -->
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="4">
                    <TextBlock x:Name="WeekHeaderText"
                               HorizontalAlignment="Center"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <Button x:Name="GotoCurrentWeekButton"
                            Opacity="0"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Center"
                            Click="GotoCurrentWeek_Click"
                            Style="{StaticResource SubtleButtonStyle}"
                            FontSize="12"
                            Padding="8,3"/>
                </StackPanel>

                <Button x:Name="NextWeekButton" Grid.Column="2"
                        Click="NextWeek_Click"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE76C;" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Day columns (Mon-Fri always; Sat/Sun width-toggled by "Show weekend") ═══ -->
        <Grid Grid.Row="1" Padding="12,8,12,12" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition x:Name="SaturdayColumn" Width="0"/>
                <ColumnDefinition x:Name="SundayColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- ── Monday ── -->
            <Border Grid.Column="0" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="MondayHeaderBorder" Grid.Row="0" CornerRadius="8,8,0,0" Padding="8,10">
                        <TextBlock x:Name="MondayHeader" TextAlignment="Center"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </Border>
                    <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    <Grid Grid.Row="1">
                        <ListView x:Name="MondayList" IsItemClickEnabled="True"
                                  ItemClick="Screenshot_ItemClick" SelectionMode="None"
                                  Padding="6" ItemTemplate="{StaticResource ThumbnailTemplate}"
                                  ItemContainerStyle="{StaticResource ThumbnailItemStyle}"/>
                        <TextBlock x:Name="MondayEmpty"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Tuesday ── -->
            <Border Grid.Column="1" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="TuesdayHeaderBorder" Grid.Row="0" CornerRadius="8,8,0,0" Padding="8,10">
                        <TextBlock x:Name="TuesdayHeader" TextAlignment="Center"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </Border>
                    <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    <Grid Grid.Row="1">
                        <ListView x:Name="TuesdayList" IsItemClickEnabled="True"
                                  ItemClick="Screenshot_ItemClick" SelectionMode="None"
                                  Padding="6" ItemTemplate="{StaticResource ThumbnailTemplate}"
                                  ItemContainerStyle="{StaticResource ThumbnailItemStyle}"/>
                        <TextBlock x:Name="TuesdayEmpty"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Wednesday ── -->
            <Border Grid.Column="2" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="WednesdayHeaderBorder" Grid.Row="0" CornerRadius="8,8,0,0" Padding="8,10">
                        <TextBlock x:Name="WednesdayHeader" TextAlignment="Center"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </Border>
                    <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    <Grid Grid.Row="1">
                        <ListView x:Name="WednesdayList" IsItemClickEnabled="True"
                                  ItemClick="Screenshot_ItemClick" SelectionMode="None"
                                  Padding="6" ItemTemplate="{StaticResource ThumbnailTemplate}"
                                  ItemContainerStyle="{StaticResource ThumbnailItemStyle}"/>
                        <TextBlock x:Name="WednesdayEmpty"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Thursday ── -->
            <Border Grid.Column="3" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="ThursdayHeaderBorder" Grid.Row="0" CornerRadius="8,8,0,0" Padding="8,10">
                        <TextBlock x:Name="ThursdayHeader" TextAlignment="Center"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </Border>
                    <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    <Grid Grid.Row="1">
                        <ListView x:Name="ThursdayList" IsItemClickEnabled="True"
                                  ItemClick="Screenshot_ItemClick" SelectionMode="None"
                                  Padding="6" ItemTemplate="{StaticResource ThumbnailTemplate}"
                                  ItemContainerStyle="{StaticResource ThumbnailItemStyle}"/>
                        <TextBlock x:Name="ThursdayEmpty"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Friday ── -->
            <Border Grid.Column="4" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="FridayHeaderBorder" Grid.Row="0" CornerRadius="8,8,0,0" Padding="8,10">
                        <TextBlock x:Name="FridayHeader" TextAlignment="Center"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </Border>
                    <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    <Grid Grid.Row="1">
                        <ListView x:Name="FridayList" IsItemClickEnabled="True"
                                  ItemClick="Screenshot_ItemClick" SelectionMode="None"
                                  Padding="6" ItemTemplate="{StaticResource ThumbnailTemplate}"
                                  ItemContainerStyle="{StaticResource ThumbnailItemStyle}"/>
                        <TextBlock x:Name="FridayEmpty"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Saturday (only shown when "Show weekend" is enabled) ── -->
            <Border x:Name="SaturdayBorder" Grid.Column="5" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="SaturdayHeaderBorder" Grid.Row="0" CornerRadius="8,8,0,0" Padding="8,10">
                        <TextBlock x:Name="SaturdayHeader" TextAlignment="Center"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </Border>
                    <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    <Grid Grid.Row="1">
                        <ListView x:Name="SaturdayList" IsItemClickEnabled="True"
                                  ItemClick="Screenshot_ItemClick" SelectionMode="None"
                                  Padding="6" ItemTemplate="{StaticResource ThumbnailTemplate}"
                                  ItemContainerStyle="{StaticResource ThumbnailItemStyle}"/>
                        <TextBlock x:Name="SaturdayEmpty"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Sunday (only shown when "Show weekend" is enabled) ── -->
            <Border x:Name="SundayBorder" Grid.Column="6" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="SundayHeaderBorder" Grid.Row="0" CornerRadius="8,8,0,0" Padding="8,10">
                        <TextBlock x:Name="SundayHeader" TextAlignment="Center"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </Border>
                    <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    <Grid Grid.Row="1">
                        <ListView x:Name="SundayList" IsItemClickEnabled="True"
                                  ItemClick="Screenshot_ItemClick" SelectionMode="None"
                                  Padding="6" ItemTemplate="{StaticResource ThumbnailTemplate}"
                                  ItemContainerStyle="{StaticResource ThumbnailItemStyle}"/>
                        <TextBlock x:Name="SundayEmpty"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>

        </Grid>

        <!-- ═══ Full-page screenshot preview overlay ═════════════════════════ -->
        <Grid x:Name="PreviewOverlay"
              Grid.RowSpan="2"
              Visibility="Collapsed">

            <!-- Dark scrim — tap anywhere outside the card to close -->
            <Rectangle Fill="Black" Opacity="0.72" Tapped="Scrim_Tapped"/>

            <!-- Centered preview card -->
            <Border CornerRadius="12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    MaxWidth="1400" MaxHeight="860"
                    Margin="60"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Large screenshot -->
                    <Image x:Name="PreviewImage"
                           Grid.Row="0"
                           Stretch="Uniform"
                           MinWidth="320" MinHeight="200"/>

                    <!-- Bottom bar: prev ← | time + title | → next -->
                    <Border Grid.Row="1"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="0,0,12,12"
                            Padding="8,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="PreviewPrevButton" Grid.Column="0"
                                    Click="PreviewPrev_Click"
                                    Style="{StaticResource SubtleButtonStyle}">
                                <FontIcon Glyph="&#xE76B;" FontSize="14"/>
                            </Button>

                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        Spacing="2">
                                <TextBlock x:Name="PreviewTimeText"
                                           TextAlignment="Center"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                                <TextBlock x:Name="PreviewTitleText"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Visibility="Collapsed"/>
                            </StackPanel>

                            <Button x:Name="PreviewNextButton" Grid.Column="2"
                                    Click="PreviewNext_Click"
                                    Style="{StaticResource SubtleButtonStyle}">
                                <FontIcon Glyph="&#xE76C;" FontSize="14"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Close button (top-right) -->
                    <Button x:Name="ClosePreviewButton" Grid.Row="0"
                            VerticalAlignment="Top" HorizontalAlignment="Right"
                            Margin="8" Width="36" Height="36"
                            Click="ClosePreview_Click"
                            Style="{StaticResource SubtleButtonStyle}">
                        <FontIcon Glyph="&#xE711;" FontSize="14"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Page>
