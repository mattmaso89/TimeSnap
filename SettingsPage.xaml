<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TimeSnap.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TimeSnap"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Background="Transparent"
    KeyDown="SettingsPage_KeyDown">

    <Page.Resources>
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="{ThemeResource SystemFillColorCriticalBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCriticalBrush}"/>
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="16" MaxWidth="640" HorizontalAlignment="Stretch">

            <TextBlock x:Name="PageHeaderText" Style="{StaticResource TitleTextBlockStyle}"/>

            <InfoBar x:Name="ScaffoldNoticeBar"
                     IsOpen="True" IsClosable="False"
                     Severity="Informational"/>

            <!-- ═══ General settings ═══ -->
            <Border CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock x:Name="GeneralHeaderText" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                    <!-- Hotkey -->
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="HotkeyLabelText" Style="{StaticResource BodyTextBlockStyle}"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HotkeyDisplayTextBox" Grid.Column="0" IsReadOnly="True" IsTabStop="False"/>
                            <Button x:Name="RecordHotkeyButton" Grid.Column="1" Click="RecordHotkeyButton_Click"/>
                            <Button x:Name="ResetHotkeyButton" Grid.Column="2" Click="ResetHotkeyButton_Click"/>
                        </Grid>
                        <TextBlock x:Name="HotkeyHintText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="HotkeyStatusText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Sound -->
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="SoundLabelText" Style="{StaticResource BodyTextBlockStyle}"/>
                        <ToggleSwitch x:Name="SoundToggle" OnContent="" OffContent="" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Show weekend -->
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="ShowWeekendLabelText" Style="{StaticResource BodyTextBlockStyle}"/>
                        <ToggleSwitch x:Name="ShowWeekendToggle" OnContent="" OffContent="" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Language -->
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="LanguageLabelText" Style="{StaticResource BodyTextBlockStyle}"/>
                        <ComboBox x:Name="LanguageComboBox" MinWidth="220" HorizontalAlignment="Left">
                            <ComboBoxItem x:Name="LangSystemItem" Tag="System"/>
                            <ComboBoxItem x:Name="LangDeItem" Tag="de"/>
                            <ComboBoxItem x:Name="LangEnItem" Tag="en"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Theme -->
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="ThemeLabelText" Style="{StaticResource BodyTextBlockStyle}"/>
                        <ComboBox x:Name="ThemeComboBox" MinWidth="220" HorizontalAlignment="Left">
                            <ComboBoxItem x:Name="ThemeSystemItem" Tag="System"/>
                            <ComboBoxItem x:Name="ThemeLightItem" Tag="Light"/>
                            <ComboBoxItem x:Name="ThemeDarkItem" Tag="Dark"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Screenshot folder -->
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="FolderLabelText" Style="{StaticResource BodyTextBlockStyle}"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FolderPathTextBox" Grid.Column="0" IsReadOnly="True"/>
                            <Button x:Name="BrowseFolderButton" Grid.Column="1" Click="BrowseFolderButton_Click"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ Monitors ═══ -->
            <Border CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="MonitorsHeaderText" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock x:Name="MonitorsHintText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <StackPanel x:Name="MonitorListPanel" Spacing="8"/>
                    <TextBlock x:Name="MonitorsStatusText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Save -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <TextBlock x:Name="SavedStatusText"
                           VerticalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed"/>
                <Button x:Name="SaveButton" Style="{StaticResource AccentButtonStyle}" Click="SaveButton_Click"/>
            </StackPanel>

            <!-- Shown after saving a different language — .resw resources only reload on restart. -->
            <InfoBar x:Name="LanguageRestartInfoBar"
                     IsOpen="False" IsClosable="True"
                     Severity="Informational">
                <InfoBar.ActionButton>
                    <Button x:Name="RestartNowButton" Click="RestartNowButton_Click"/>
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- ═══ Danger zone ═══ -->
            <Border CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                    BorderThickness="1"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="DangerZoneHeaderText" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock x:Name="DangerZoneHintText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <Button x:Name="DeleteAllButton"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="DeleteAllButton_Click"
                            HorizontalAlignment="Left"/>
                    <TextBlock x:Name="DeleteStatusText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
